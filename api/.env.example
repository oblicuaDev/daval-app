PORT=3000
NODE_ENV=development
TZ=America/Bogota

# ─── Base de datos ────────────────────────────────────────────────────────────
#
# OPCIÓN A — Supabase (o cualquier PostgreSQL administrado con SSL)
# DATABASE_URL tiene precedencia sobre las variables DB_* individuales.
# Formato: postgresql://[USER]:[PASSWORD]@[HOST]:[PORT]/[DB]
# Puerto 5432 = conexión directa (recomendada con pg.Pool propio)
# Puerto 6543 = PgBouncer/pooler (evitar con pg.Pool — causa conflictos con PREPARE)
DATABASE_URL=postgresql://postgres:[PASSWORD]@db.[PROJECT-REF].supabase.co:5432/postgres

# OPCIÓN B — PostgreSQL local (dev sin Supabase)
# Solo aplica si DATABASE_URL no está definida.
DB_HOST=localhost
DB_PORT=5432
DB_NAME=daval_db_dev
DB_USER=daval_dev
DB_PASSWORD=daval_dev_pass
DB_MAX_CONNECTIONS=10

# ─── Auth JWT ────────────────────────────────────────────────────────────────
# Genera secretos seguros con: openssl rand -base64 32
JWT_SECRET=cambia-esto-en-produccion
JWT_EXPIRES_IN=8h
JWT_REFRESH_SECRET=cambia-esto-tambien-en-produccion
JWT_REFRESH_EXPIRES_IN=30d

# ─── CORS ────────────────────────────────────────────────────────────────────
# En producción: URL exacta de Vercel (sin trailing slash)
# Múltiples orígenes: separados por coma
# CORS_ORIGIN=https://tu-app.vercel.app,https://daval.com
CORS_ORIGIN=http://localhost:5173

# ─── SIIGO (opcional — también configurable en tabla siigo_settings) ─────────
# SIIGO_BASE_URL=https://api.siigo.com

# ─── Email SMTP (notificaciones automáticas al asesor) ───────────────────────
# Si se omiten, el sistema funciona sin emails (solo logea un warning).
# Proveedores recomendados: SendGrid, Mailgun, Gmail SMTP, AWS SES.
#
# Gmail: habilitar "App Password" en cuenta → Security → 2FA → App passwords
# SMTP_HOST=smtp.gmail.com
# SMTP_PORT=587
# SMTP_SECURE=false
# SMTP_USER=notificaciones@tudominio.com
# SMTP_PASS=npkakkalwnsiwceo
# SMTP_FROM="DAVAL App <notificaciones@tudominio.com>"
