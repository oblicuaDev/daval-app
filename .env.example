# URL base del backend Express (sin trailing slash).
# Dev local:     http://localhost:3000/api
# Vercel (prod): https://tu-app.vercel.app/api
# (En Vercel el frontend y la API comparten el mismo dominio)
VITE_API_URL=http://localhost:3000/api

# Google Maps — necesita Maps JavaScript API + Geocoding API habilitadas
# Obtener en: console.cloud.google.com → APIs & Services → Credentials
VITE_GOOGLE_MAPS_API_KEY=
